{
  "name": "refactory",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "vp run -r --parallel dev",
    "dev:web": "vp run @refactory/web#dev",
    "dev:api": "vp run @refactory/api#dev",
    "build": "vp run -r build",
    "check": "vp run -r check",
    "start": "vp run @refactory/api#start"
  },
  "devDependencies": {
    "@effect/language-service": "^0.84.3",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "vite-plus": "^0.1.15",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
